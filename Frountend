            <div id="pdfAppointmentsSection" class="pdf-section"></div>
            <div class="footer-note" style="text-align:center; margin-top:40px; padding-top:20px; border-top:2px dashed #ffb7c5;"><p>🌸 Every feeling is valid, every step is progress 🌸</p><p>💕 You are doing amazing, beautiful soul! 💕</p></div>
        </div>
    </div>

    <footer>
        <p>🌸 SereneMind - Your Gentle Companion on the Path to Inner Peace 🌸</p>
        <p>📞 24/7 Heartfelt Support: 988 | 💌 hello@serenemind.com</p>
        <p>✨ You are loved, you are worthy, you are enough ✨</p>
    </footer>

    <script>
        // Data Storage
        let moodHistory = [], appointments = [], goals = [], notes = [], cart = [], chatHistory = [];
        let userName = "Guest", userEmail = "", selectedPayment = "", selectedDoctor = null;

        const productList = [
            { id: 1, name: "Mindfulness Journal", price: 24.99, desc: "Daily prompts for gentle reflection", icon: "📔" },
            { id: 2, name: "Calm Essential Oil Set", price: 39.99, desc: "Lavender, chamomile, bergamot", icon: "🌿" },
            { id: 3, name: "Stress Relief Tea", price: 19.99, desc: "Organic calming herbal blend", icon: "🍵" },
            { id: 4, name: "Meditation Cushion", price: 49.99, desc: "Ergonomic support for peace", icon: "🧘" },
            { id: 5, name: "Gratitude Cards", price: 14.99, desc: "52 daily gratitude prompts", icon: "💝" },
            { id: 6, name: "Wellness Planner", price: 29.99, desc: "Track your beautiful journey", icon: "📅" }
        ];

        const doctors = [
            { name: "Dr. Revanth Kumar", specialty: "Senior Psychiatrist", exp: "15+ years", rating: 4.9, reviews: 128, icon: "👨‍⚕️" },
            { name: "Dr. Sai Lakshmi", specialty: "Clinical Psychologist", exp: "12+ years", rating: 4.8, reviews: 95, icon: "👩‍⚕️" },
            { name: "Dr. Meera Nair", specialty: "Mental Health Counselor", exp: "8+ years", rating: 4.9, reviews: 112, icon: "👩‍⚕️" }
        ];

        function loadData() {
            moodHistory = JSON.parse(localStorage.getItem('serene_moods') || '[]');
            appointments = JSON.parse(localStorage.getItem('serene_appointments') || '[]');
            goals = JSON.parse(localStorage.getItem('serene_goals') || '[]');
            notes = JSON.parse(localStorage.getItem('serene_notes') || '[]');
            cart = JSON.parse(localStorage.getItem('serene_cart') || '[]');
            chatHistory = JSON.parse(localStorage.getItem('serene_chat') || '[]');
            userName = localStorage.getItem('serene_name') || 'Guest';
            userEmail = localStorage.getItem('serene_email') || '';
        }
        function saveData() {
            localStorage.setItem('serene_moods', JSON.stringify(moodHistory));
            localStorage.setItem('serene_appointments', JSON.stringify(appointments));
            localStorage.setItem('serene_goals', JSON.stringify(goals));
            localStorage.setItem('serene_notes', JSON.stringify(notes));
            localStorage.setItem('serene_cart', JSON.stringify(cart));
            localStorage.setItem('serene_chat', JSON.stringify(chatHistory));
            localStorage.setItem('serene_name', userName);
            localStorage.setItem('serene_email', userEmail);
        }

        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
            if (pageId === 'dashboard') updateDashboard();
            if (pageId === 'mood') updateMoodDisplay();
            if (pageId === 'products') { renderProducts(); renderCart(); }
            if (pageId === 'appointments') { renderDoctors(); updateAppointmentsDisplay(); }
            if (pageId === 'profile') updateProfileDisplay();
            if (window.innerWidth <= 768) document.getElementById('navLinks').classList.remove('active');
        }
        function toggleMenu() { document.getElementById('navLinks').classList.toggle('active'); }

        // PDF Export
        function exportBeautifulPDF() {
            const moodSec = document.getElementById('pdfMoodSection'), chatSec = document.getElementById('pdfChatSection'), goalsSec = document.getElementById('pdfGoalsSection'), notesSec = document.getElementById('pdfNotesSection'), aptSec = document.getElementById('pdfAppointmentsSection');
            moodSec.innerHTML = '<h3>🌊 My Mood Journey</h3>' + (moodHistory.length === 0 ? '<p>No moods recorded yet.</p>' : moodHistory.slice().reverse().map(m => `<div class="mood-entry-pdf">${m.emoji} Feeling ${getMoodName(m.emoji)} (${m.value}/10) - ${new Date(m.date).toLocaleString()}</div>`).join('') + `<div style="margin-top:15px;">✨ Average Mood: ${Math.round(moodHistory.reduce((s,m)=>s+m.value,0)/moodHistory.length || 0)}/10 ✨</div>`);
            chatSec.innerHTML = '<h3>💬 Heartfelt Conversations</h3>' + (chatHistory.length === 0 ? '<p>No conversations yet.</p>' : chatHistory.slice().reverse().slice(0,20).map(c => `<div class="chat-entry-pdf"><strong>${c.type === 'user' ? '🌸 Me' : '🤗 SereneAI'}:</strong> ${c.text}</div>`).join(''));
            goalsSec.innerHTML = '<h3>🎯 Gentle Intentions</h3>' + (goals.length === 0 ? '<p>No goals yet.</p>' : goals.map(g => `<div class="goal-pdf">${g.completed ? '✓' : '○'} ${g.text}</div>`).join(''));
            notesSec.innerHTML = '<h3>📝 Heartfelt Reflections</h3>' + (notes.length === 0 ? '<p>No reflections yet.</p>' : notes.slice().reverse().map(n => `<div class="goal-pdf">📖 ${n.text}<br><small>${new Date(n.createdAt).toLocaleString()}</small></div>`).join(''));
            aptSec.innerHTML = '<h3>📅 Self-Care Sessions</h3>' + (appointments.length === 0 ? '<p>No appointments yet.</p>' : appointments.map(a => `<div class="goal-pdf">🌸 ${a.doctor} - ${a.date} at ${a.time}</div>`).join(''));
            document.getElementById('pdfDate').innerText = new Date().toLocaleString();
            const element = document.getElementById('pdfJournalContent');
            html2pdf().set({ margin: [0.5,0.5,0.5,0.5], filename: `SereneMind_Journey_${new Date().toISOString().slice(0,19)}.pdf`, image: { type: 'jpeg', quality: 0.98 }, html2canvas: { scale: 2 }, jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' } }).from(element).save();
        }
        function getMoodName(emoji) { const moods = { '😊':'Radiant','😌':'Peaceful','😐':'Calm','😔':'Tender','😢':'Heavy','😰':'Anxious' }; return moods[emoji] || 'Beautiful'; }

        // Mood Functions
        function logMood(emoji, value) {
            moodHistory.push({ emoji, value, date: new Date().toISOString() });
            saveData();
            updateMoodDisplay();
            document.getElementById('moodFeedback').innerHTML = `🌸 Mood logged: ${emoji} (${value}/10) - Thank you for honoring your feelings! 💕`;
            document.getElementById('moodFeedback').style.display = 'block';
            setTimeout(() => document.getElementById('moodFeedback').style.display = 'none', 3000);
        }
        function updateMoodDisplay() {
            if (moodHistory.length === 0) { document.getElementById('avgMood').innerText = '0'; document.getElementById('bestMood').innerText = '-'; document.getElementById('moodStreak').innerText = '0'; document.getElementById('totalMoods').innerText = '0'; document.getElementById('moodHistoryList').innerHTML = '<p>No moods journaled yet. Begin your gentle practice 🌸</p>'; return; }
            const avg = Math.round(moodHistory.reduce((s,m)=>s+m.value,0)/moodHistory.length);
            const best = Math.max(...moodHistory.map(m=>m.value));
            document.getElementById('avgMood').innerText = avg; document.getElementById('bestMood').innerText = best; document.getElementById('moodStreak').innerText = moodHistory.length; document.getElementById('totalMoods').innerText = moodHistory.length;
            document.getElementById('moodHistoryList').innerHTML = moodHistory.slice().reverse().slice(0,10).map(m => `<div style="padding:10px; border-bottom:1px solid #ffe4ed;">${m.emoji} (${m.value}/10) - ${new Date(m.date).toLocaleString()}</div>`).join('');
        }

        // Products
        function renderProducts() { document.getElementById('productsGrid').innerHTML = productList.map(p => `<div class="product-card"><div class="product-image">${p.icon}</div><div class="product-info"><h3>${p.name}</h3><p>${p.desc}</p><p class="product-price">$${p.price}</p><button class="btn-primary" onclick="addToCart(${p.id})">Add to Cart 💕</button></div></div>`).join(''); }
        function addToCart(id) { const p = productList.find(p => p.id === id); cart.push(p); saveData(); renderCart(); alert(`${p.name} added to your cart with love 💕`); }
        function renderCart() { const cartDiv = document.getElementById('cartItems'); if(cart.length===0) cartDiv.innerHTML = '<p>Your cart is empty. Add some self-care treasures 🌸</p>'; else cartDiv.innerHTML = cart.map((item,i) => `<div style="display:flex; justify-content:space-between; padding:10px; border-bottom:1px solid #ffe4ed;"><span>${item.icon} ${item.name}</span><span>$${item.price}</span><button onclick="removeFromCart(${i})" style="background:#ffb7c5; border:none; padding:5px 15px; border-radius:20px;">Remove</button></div>`).join(''); document.getElementById('cartTotal').innerText = cart.reduce((s,i)=>s+i.price,0).toFixed(2); }
        function removeFromCart(i) { cart.splice(i,1); saveData(); renderCart(); }
        function openCheckout() { if(cart.length===0) alert('Your cart is empty!'); else { document.getElementById('modalTotal').innerText = cart.reduce((s,i)=>s+i.price,0).toFixed(2); document.getElementById('checkoutModal').style.display = 'flex'; } }
        function closeCheckout() { document.getElementById('checkoutModal').style.display = 'none'; }
        function selectPayment(type) { selectedPayment = type; document.getElementById('paymentOnline').classList.remove('selected'); document.getElementById('paymentOffline').classList.remove('selected'); document.getElementById(type==='online'?'paymentOnline':'paymentOffline').classList.add('selected'); }
        function processOrder() { const name=document.getElementById('fullName').value, email=document.getElementById('emailAddress').value, phone=document.getElementById('phoneNumber').value, addr=document.getElementById('addressLine').value, city=document.getElementById('city').value, zip=document.getElementById('zipCode').value; if(!name||!email||!phone||!addr||!city||!zip) { alert('Please fill all address details 💕'); return; } if(!selectedPayment) { alert('Please select a payment method 💕'); return; } alert(`✨ Order Placed with Love! ✨\n\nThank you ${name}!\nTotal: $${cart.reduce((s,i)=>s+i.price,0).toFixed(2)}\nPayment: ${selectedPayment==='online'?'Online Payment':'Cash on Delivery'}\nShipping to: ${addr}, ${city}, ${zip}\n\nYour self-care treasures are on their way! 💕`); cart = []; saveData(); renderCart(); closeCheckout(); }

        // Doctors & Appointments
        function renderDoctors() { document.getElementById('doctorList').innerHTML = doctors.map(d => `<div class="doctor-card" onclick="selectDoctor('${d.name}')" data-doctor="${d.name}"><div class="doctor-avatar">${d.icon}</div><div><strong>${d.name}</strong><br>${d.specialty} | ${d.exp}<br>⭐ ${d.rating} (${d.reviews} reviews)</div></div>`).join(''); }
        function selectDoctor(name) { selectedDoctor = name; document.querySelectorAll('.doctor-card').forEach(c => c.classList.remove('selected')); event.currentTarget.classList.add('selected'); }
        function updateAppointmentsDisplay() { const list = document.getElementById('appointmentsList'); if(appointments.length===0) list.innerHTML='<p>No sessions booked yet. Time to nurture yourself 💕</p>'; else list.innerHTML=appointments.map(a=>`<div style="padding:12px; border-bottom:1px solid #ffe4ed;">🌸 ${a.doctor} - ${a.date} at ${a.time}</div>`).join(''); }

        // Profile Functions
        function updateProfileDisplay() {
            document.getElementById('profileName').value = userName === 'Guest' ? '' : userName;
            document.getElementById('profileEmail').value = userEmail;
            document.getElementById('goalsList').innerHTML = goals.length===0 ? '<p>No gentle intentions yet. Add your first intention 🌸</p>' : goals.map(g => `<div style="display:flex; gap:10px; padding:12px; background:#fff5f8; margin-bottom:8px; border-radius:20px;"><input type="checkbox" ${g.completed?'checked':''} onchange="toggleGoal(${g.id})"><span style="flex:1; ${g.completed?'text-decoration:line-through;':''}">${escapeHtml(g.text)}</span><button onclick="deleteGoal(${g.id})" style="background:none; border:none; color:#ff9eb0;">🗑️</button></div>`).join('');
            document.getElementById('notesList').innerHTML = notes.length===0 ? '<p>No reflections yet. Write from your heart 🌸</p>' : notes.slice().reverse().map(n => `<div style="padding:12px; background:#fff5f8; margin-bottom:8px; border-radius:20px;">${escapeHtml(n.text)}<br><small>${new Date(n.createdAt).toLocaleString()}</small></div>`).join('');
        }
        function escapeHtml(t){const d=document.createElement('div');d.textContent=t;return d.innerHTML;}
        function addGoal(){const i=document.getElementById('newGoal'),t=i.value.trim();if(t){goals.push({id:Date.now(),text:t,completed:false,createdAt:new Date().toISOString()});saveData();i.value='';updateProfileDisplay();}}
        function toggleGoal(id){const g=goals.find(g=>g.id===id);if(g)g.completed=!g.completed;saveData();updateProfileDisplay();}
        function deleteGoal(id){goals=goals.filter(g=>g.id!==id);saveData();updateProfileDisplay();}
        function addNote(){const t=document.getElementById('newNote').value.trim();if(t){notes.push({id:Date.now(),text:t,createdAt:new Date().toISOString()});saveData();document.getElementById('newNote').value='';updateProfileDisplay();}}
        function updateDashboard(){document.getElementById('dashChatCount').innerText=chatHistory.length;document.getElementById('dashMoodCount').innerText=moodHistory.length;document.getElementById('dashApptCount').innerText=appointments.length;const insights=['You are worthy of all the love and care in the world 🌸','Breathe deeply - you are exactly where you need to be 💕','Your feelings are valid, your journey is beautiful 🌈','Take a moment to honor how far you\'ve come ✨'];document.getElementById('dailyInsight').innerHTML=insights[Math.floor(Math.random()*insights.length)];}
        function clearAllData(){if(confirm('🌿 This will reset your journey. Are you ready for a fresh start?')){localStorage.clear();location.reload();}}

        // Chat Functions
        function addMessage(type,text){const div=document.getElementById('chatMessages');const msg=document.createElement('div');msg.className=`message ${type}`;msg.innerHTML=`<div class="message-content">${text}</div>`;div.appendChild(msg);div.scrollTop=div.scrollHeight;}
        function getAIResponse(msg){const l=msg.toLowerCase();if(l.includes('sad')) return "💙 Your feelings are valid. I'm here with you. Would you like to talk about it?";if(l.includes('anxiety')) return "🌿 Let's breathe together. Inhale... exhale... You're safe. 💕";if(l.includes('happy')) return "✨ What beautiful energy! I'm so glad you're feeling joy!";return "🌸 Thank you for sharing your beautiful heart with me. I'm listening with so much love. Tell me more.";}
        function sendMessage(){const i=document.getElementById('chatInput'),msg=i.value.trim();if(!msg)return;addMessage('user',msg);chatHistory.push({type:'user',text:msg});const res=getAIResponse(msg);setTimeout(()=>{addMessage('bot',res);chatHistory.push({type:'bot',text:res});saveData();},500);i.value='';saveData();}
        function clearChat(){if(confirm('Clear our conversation?')){chatHistory=[];document.getElementById('chatMessages').innerHTML='<div class="message bot"><div class="message-content">Hello beautiful soul! How are you feeling today? I\'m here to hold space for you. 💕</div></div>';saveData();}}

        // Event Listeners
        document.querySelectorAll('.mood-btn').forEach(btn=>{btn.addEventListener('click',()=>{logMood(btn.dataset.mood,parseInt(btn.dataset.value));});});
        document.getElementById('appointmentForm').addEventListener('submit',(e)=>{e.preventDefault();if(!selectedDoctor){alert('Please select a caring professional 💕');return;}const apt={id:Date.now(),doctor:selectedDoctor,name:document.getElementById('aptName').value,email:document.getElementById('aptEmail').value,phone:document.getElementById('aptPhone').value,date:document.getElementById('aptDate').value,time:document.getElementById('aptTime').value,reason:document.getElementById('aptReason').value};if(!apt.name||!apt.email||!apt.phone||!apt.date){alert('Please fill all fields with love 💕');return;}appointments.push(apt);saveData();alert(`✨ Session booked with ${apt.doctor} on ${apt.date}! You've taken a beautiful step for yourself. 💕`);updateAppointmentsDisplay();document.getElementById('appointmentForm').reset();selectedDoctor=null;});
        document.getElementById('profileForm').addEventListener('submit',(e)=>{e.preventDefault();userName=document.getElementById('profileName').value||'Guest';userEmail=document.getElementById('profileEmail').value;saveData();updateProfileDisplay();alert('Your sacred space has been updated 💕');});

        loadData(); updateDashboard(); updateMoodDisplay(); renderProducts(); renderCart(); renderDoctors(); updateAppointmentsDisplay(); updateProfileDisplay();
    </script>
</body>
</html>
