    <!-- PDF Template -->
    <div id="pdfTemplate" class="pdf-content">
        <div class="pdf-journal" id="pdfJournalContent">
            <div class="pdf-header"><h1>🌸 My SereneMind Journey 🌸</h1><div class="pdf-date">Created with love on <span id="pdfDate"></span></div><div>✨ A beautiful record of my mental wellness journey ✨</div></div>
