            </ul>
            <div class="mobile-menu" onclick="toggleMenu()">☰</div>
        </div>
    </nav>

    <div class="page-container">
        <!-- HOME PAGE -->
        <div id="home" class="page active">
            <div style="text-align: center; padding: 3rem; background: linear-gradient(135deg, #fff5f8 0%, #ffe8f0 100%); border-radius: 50px; margin: 1rem 0;">
                <h2 style="font-family: 'Playfair Display', serif; font-size: 2.5rem; color: #ff8aa8;">🌸 Your Beautiful Journey Awaits 🌸</h2>
                <p style="font-size: 1.1rem; color: #aa8c9e; margin: 1rem 0;">Every step you take is a precious part of your story</p>
                <button class="export-pdf-btn" onclick="exportBeautifulPDF()"><i class="fas fa-download"></i> Download Your Beautiful Journal 📔</button>
            </div>
            <div class="feature-grid">
                <div class="feature-card" onclick="showPage('chatbot')"><div class="feature-icon">🤗</div><h3>SereneAI Companion</h3><p>24/7 compassionate listening and support</p></div>
                <div class="feature-card" onclick="showPage('mood')"><div class="feature-icon">📖</div><h3>Mood Journal</h3><p>Track emotions with beautiful insights</p></div>
                <div class="feature-card" onclick="showPage('products')"><div class="feature-icon">🛍️</div><h3>Wellness Boutique</h3><p>Curated self-care products</p></div>
                <div class="feature-card" onclick="showPage('appointments')"><div class="feature-icon">💝</div><h3>Heartfelt Consultations</h3><p>Connect with caring professionals</p></div>
            </div>
            <div class="feature-grid">
                <div class="beauty-card" style="text-align:center;"><div style="font-size:3rem;">🌅</div><h3>Morning Rituals</h3><p>Start your day with mindfulness</p></div>
                <div class="beauty-card" style="text-align:center;"><div style="font-size:3rem;">📝</div><h3>Gratitude Practice</h3><p>Find joy in small moments</p></div>
                <div class="beauty-card" style="text-align:center;"><div style="font-size:3rem;">🧘</div><h3>Mindful Moments</h3><p>Breathe, relax, reset</p></div>
            </div>
            <div class="beauty-card" style="text-align:center; background: linear-gradient(135deg, #ffb7c5 0%, #ff9eb0 100%); color: white;">
                <h2 style="color: white;">💖 Daily Self-Care Reminder</h2>
                <p style="font-size: 1.2rem; margin-top: 1rem;">"You are worthy of love, care, and happiness. Take a deep breath—you're doing amazing."</p>
                <button class="btn-primary" style="background: white; color: #ff9eb0; margin-top: 1.5rem;" onclick="showPage('mood')">Check In With Yourself →</button>
            </div>
        </div>

        <!-- DASHBOARD -->
        <div id="dashboard" class="page">
            <h1 class="section-title">📊 Your Wellness Dashboard</h1>
            <div class="feature-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
                <div class="beauty-card" style="text-align:center;"><div class="stat-number" id="dashChatCount" style="font-size:3rem; font-weight:bold; color:#ff9eb0;">0</div><p>Heartfelt Chats</p></div>
                <div class="beauty-card" style="text-align:center;"><div class="stat-number" id="dashMoodCount" style="font-size:3rem; font-weight:bold; color:#ff9eb0;">0</div><p>Moods Journaled</p></div>
                <div class="beauty-card" style="text-align:center;"><div class="stat-number" id="dashApptCount" style="font-size:3rem; font-weight:bold; color:#ff9eb0;">0</div><p>Care Sessions</p></div>
            </div>
            <div class="beauty-card"><h3>🌸 Today's Gentle Reminder</h3><p id="dailyInsight">You are enough, just as you are. Take a moment to breathe. 💕</p></div>
        </div>

        <!-- CHATBOT -->
        <div id="chatbot" class="page">
            <div class="beauty-card"><h2>🤗 SereneAI - Your Gentle Companion</h2><p>I'm here to listen, always.</p></div>
            <div class="chat-messages" id="chatMessages"><div class="message bot"><div class="message-content">Hello beautiful soul! How are you feeling today? I'm here to hold space for you. 💕</div></div></div>
            <div style="display: flex; gap: 1rem; margin-top: 1rem;"><input type="text" id="chatInput" placeholder="Share what's on your heart..." style="flex:1;"><button onclick="sendMessage()" class="btn-primary">Send</button><button onclick="clearChat()" style="background:#ffb7c5; border:none; border-radius:50px; padding:0 20px;">Clear</button></div>
        </div>

        <!-- MOOD TRACKER -->
        <div id="mood" class="page">
            <h1 class="section-title">🌊 Gentle Mood Journal</h1>
            <p style="text-align:center;">How does your heart feel today?</p>
            <div class="mood-grid" id="moodGrid">
                <button class="mood-btn" data-mood="😊" data-value="10">😊<br>Radiant</button>
                <button class="mood-btn" data-mood="😌" data-value="8">😌<br>Peaceful</button>
                <button class="mood-btn" data-mood="😐" data-value="5">😐<br>Calm</button>
                <button class="mood-btn" data-mood="😔" data-value="3">😔<br>Tender</button>
                <button class="mood-btn" data-mood="😢" data-value="2">😢<br>Heavy</button>
                <button class="mood-btn" data-mood="😰" data-value="2">😰<br>Anxious</button>
            </div>
            <div id="moodFeedback" style="background:#ffe9e6; padding:1rem; border-radius:20px; display:none; margin:1rem 0;"></div>
            <div class="feature-grid" style="grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));">
                <div class="beauty-card" style="text-align:center;"><h3 id="avgMood">0</h3><p>Avg Mood</p></div>
                <div class="beauty-card" style="text-align:center;"><h3 id="bestMood">-</h3><p>Best Mood</p></div>
                <div class="beauty-card" style="text-align:center;"><h3 id="moodStreak">0</h3><p>Streak</p></div>
                <div class="beauty-card" style="text-align:center;"><h3 id="totalMoods">0</h3><p>Entries</p></div>
            </div>
            <div class="beauty-card"><h3>📅 Recent Gentle Reflections</h3><div id="moodHistoryList"></div></div>
        </div>

        <!-- PRODUCTS -->
        <div id="products" class="page">
            <h1 class="section-title">🛍️ Serene Wellness Boutique</h1>
            <p style="text-align:center;">Beautiful self-care treasures for your journey</p>
            <div class="product-grid" id="productsGrid"></div>
            <div class="beauty-card"><h3>🛒 Your Self-Care Cart</h3><div id="cartItems"></div><div class="cart-total" style="font-size:1.5rem; font-weight:bold; text-align:right; margin-top:1rem;">Total: $<span id="cartTotal">0</span></div><button class="btn-primary" onclick="openCheckout()">Checkout with Love 💕</button></div>
        </div>

        <!-- APPOINTMENTS -->
        <div id="appointments" class="page">
            <h1 class="section-title">👩‍⚕️ Heartfelt Consultations</h1>
            <p style="text-align:center;">Connect with caring professionals</p>
            <div id="doctorList"></div>
            <div class="beauty-card"><h3>📅 Book a Gentle Session</h3>
                <form id="appointmentForm"><input type="text" id="aptName" placeholder="Your Name" style="width:100%; margin-bottom:1rem;"><input type="email" id="aptEmail" placeholder="Email" style="width:100%; margin-bottom:1rem;"><input type="tel" id="aptPhone" placeholder="Phone" style="width:100%; margin-bottom:1rem;"><input type="date" id="aptDate" style="width:100%; margin-bottom:1rem;"><select id="aptTime" style="width:100%; margin-bottom:1rem;"><option>10:00 AM</option><option>11:00 AM</option><option>2:00 PM</option><option>3:00 PM</option><option>4:00 PM</option></select><textarea id="aptReason" rows="3" placeholder="What would you like to talk about?" style="width:100%; margin-bottom:1rem;"></textarea><button type="submit" class="btn-primary">Book with Love 💕</button></form>
            </div>
            <div class="beauty-card"><h3>📅 Your Sacred Sessions</h3><div id="appointmentsList"></div></div>
        </div>

        <!-- PROFILE -->
        <div id="profile" class="page">
            <h1 class="section-title">👤 Your Sacred Space</h1>
            <div class="beauty-card"><form id="profileForm"><input type="text" id="profileName" placeholder="Your Name" style="width:100%; margin-bottom:1rem;"><input type="email" id="profileEmail" placeholder="Email" style="width:100%; margin-bottom:1rem;"><button type="submit" class="btn-primary">Save Your Essence</button></form></div>
            <div class="beauty-card"><h3>🎯 Gentle Intentions</h3><div style="display:flex; gap:1rem;"><input type="text" id="newGoal" placeholder="Add a gentle intention..." style="flex:1;"><button onclick="addGoal()" class="btn-primary">Plant Intention</button></div><div id="goalsList"></div></div>
            <div class="beauty-card"><h3>📝 Heartfelt Reflections</h3><textarea id="newNote" rows="3" placeholder="Write from your heart..." style="width:100%; margin-bottom:1rem;"></textarea><button onclick="addNote()" class="btn-primary">Save Reflection</button><div id="notesList"></div></div>
            <div class="beauty-card"><button onclick="exportBeautifulPDF()" class="btn-primary" style="background:#28a745; margin-right:1rem;">📥 Export Your Journey</button><button onclick="clearAllData()" style="background:#ffb7c5; border:none; padding:12px 30px; border-radius:50px;">🌿 Reset & Begin Anew</button></div>
        </div>
    </div>

    <!-- Checkout Modal -->
    <div id="checkoutModal" class="modal">
        <div class="modal-content">
            <h2 style="color:#ff8aa8;">💕 Complete Your Order</h2>
            <input type="text" id="fullName" placeholder="Full Name" style="width:100%; margin:10px 0;"><input type="email" id="emailAddress" placeholder="Email" style="width:100%; margin:10px 0;"><input type="tel" id="phoneNumber" placeholder="Phone" style="width:100%; margin:10px 0;"><input type="text" id="addressLine" placeholder="Street Address" style="width:100%; margin:10px 0;"><input type="text" id="city" placeholder="City" style="width:100%; margin:10px 0;"><input type="text" id="zipCode" placeholder="Zip Code" style="width:100%; margin:10px 0;">
