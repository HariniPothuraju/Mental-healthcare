<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>🌸 SereneMind - Your Beautiful Mental Wellness Companion</title>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Quicksand', 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #fff5f8 0%, #ffe8f0 100%);
            min-height: 100vh;
            overflow-x: hidden;
        }

        ::-webkit-scrollbar { width: 10px; }
        ::-webkit-scrollbar-track { background: #ffe4ed; border-radius: 10px; }
        ::-webkit-scrollbar-thumb { background: linear-gradient(135deg, #ffb7c5 0%, #ff9eb0 100%); border-radius: 10px; }

        .navbar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            box-shadow: 0 5px 30px rgba(255, 150, 180, 0.1);
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            border-bottom: 1px solid rgba(255, 183, 197, 0.3);
        }
        .nav-container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
        }
        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.6rem;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Playfair Display', serif;
        }
        .logo-icon { font-size: 2rem; animation: float 3s ease-in-out infinite; }
        @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
        .logo-text { background: linear-gradient(135deg, #ff9eb0 0%, #ffb7c5 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .nav-links { display: flex; list-style: none; gap: 1rem; }
        .nav-links a {
            text-decoration: none;
            color: #aa8c9e;
            font-weight: 600;
            transition: all 0.3s;
            cursor: pointer;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
        }
        .nav-links a:hover, .nav-links a.active { background: linear-gradient(135deg, #ffb7c5 0%, #ff9eb0 100%); color: white; transform: translateY(-2px); }
        .mobile-menu { display: none; font-size: 1.5rem; cursor: pointer; color: #ff9eb0; }

        .page-container { max-width: 1400px; margin: 80px auto 0; padding: 2rem; min-height: calc(100vh - 160px); }
        .page { display: none; animation: fadeInUp 0.6s cubic-bezier(0.4, 0, 0.2, 1); }
        .page.active { display: block; }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

        .section-title {
            text-align: center;
            font-size: 2.5rem;
            margin: 3rem 0 1rem;
            font-family: 'Playfair Display', serif;
            background: linear-gradient(135deg, #ff9eb0 0%, #ffb7c5 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .beauty-card {
            background: white;
            border-radius: 35px;
            padding: 2rem;
            box-shadow: 0 15px 35px rgba(255, 150, 180, 0.1);
            border: 1px solid rgba(255, 183, 197, 0.3);
            transition: all 0.3s;
        }
        .beauty-card:hover { transform: translateY(-5px); box-shadow: 0 20px 40px rgba(255, 150, 180, 0.2); }
        .feature-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin: 2rem 0; }
        .feature-card {
            background: white;
            border-radius: 30px;
            padding: 2rem;
            text-align: center;
            transition: all 0.4s;
            cursor: pointer;
            box-shadow: 0 15px 35px rgba(0,0,0,0.05);
            border: 1px solid rgba(255,183,197,0.3);
        }
        .feature-card:hover { transform: translateY(-10px); border-color: #ffb7c5; }
        .feature-icon { font-size: 3.5rem; margin-bottom: 1rem; }

        .product-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin: 2rem 0; }
        .product-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            transition: all 0.4s;
            border: 1px solid rgba(255,183,197,0.3);
        }
        .product-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(255,150,180,0.2); }
        .product-image { height: 200px; background: linear-gradient(135deg, #fff5f8 0%, #ffe8f0 100%); display: flex; align-items: center; justify-content: center; font-size: 5rem; }
        .product-info { padding: 1.5rem; }
        .product-price { font-size: 1.5rem; color: #ff9eb0; font-weight: bold; margin: 0.5rem 0; }

        .mood-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 1rem; margin: 2rem 0; }
        .mood-btn {
            text-align: center;
            padding: 1rem;
            background: linear-gradient(135deg, #fff5f8 0%, #ffe8f0 100%);
            border: none;
            border-radius: 25px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 2rem;
        }
        .mood-btn:hover { transform: scale(1.05); box-shadow: 0 10px 25px rgba(255,107,107,0.2); }

        .doctor-card {
            display: flex;
            gap: 1.5rem;
            padding: 1.5rem;
            background: white;
            border-radius: 25px;
            margin-bottom: 1rem;
            cursor: pointer;
            transition: all 0.3s;
            border: 2px solid transparent;
        }
        .doctor-card:hover { transform: translateX(8px); }
        .doctor-card.selected { border-color: #ff9eb0; background: #fff5f8; }
        .doctor-avatar { width: 80px; height: 80px; background: linear-gradient(135deg, #ffb7c5 0%, #ff9eb0 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; color: white; }

        .chat-messages { height: 400px; overflow-y: auto; background: #fff5f8; border-radius: 30px; padding: 1rem; }
        .message { margin-bottom: 1rem; display: flex; }
        .message.user { justify-content: flex-end; }
        .message-content { max-width: 70%; padding: 12px 18px; border-radius: 20px; }
        .message.user .message-content { background: linear-gradient(135deg, #ffb7c5 0%, #ff9eb0 100%); color: white; }
        .message.bot .message-content { background: white; border: 1px solid #ffe4ed; color: #aa8c9e; }

        .btn-primary {
            background: linear-gradient(135deg, #ffb7c5 0%, #ff9eb0 100%);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(255,158,176,0.4); }
        .export-pdf-btn {
            background: linear-gradient(135deg, #ffb7c5 0%, #ff9eb0 100%);
            color: white;
            border: none;
            padding: 15px 35px;
            border-radius: 50px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            margin-top: 1rem;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        input, select, textarea {
            font-family: 'Quicksand', sans-serif;
            padding: 12px;
            border: 2px solid #ffe4ed;
            border-radius: 25px;
            outline: none;
            transition: all 0.3s;
        }
        input:focus, select:focus, textarea:focus { border-color: #ffb7c5; }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(5px);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }
        .modal-content {
            background: white;
            border-radius: 40px;
            padding: 2rem;
            max-width: 500px;
            width: 90%;
            max-height: 85vh;
            overflow-y: auto;
            animation: modalSlideIn 0.3s ease;
        }
        @keyframes modalSlideIn { from { opacity: 0; transform: translateY(-50px); } to { opacity: 1; transform: translateY(0); } }
        .payment-option { padding: 1rem; margin: 0.5rem 0; border: 2px solid #ffe4ed; border-radius: 20px; cursor: pointer; }
        .payment-option.selected { border-color: #ff9eb0; background: #fff5f8; }

        .pdf-content { display: none; }
        .pdf-journal {
            background: linear-gradient(135deg, #fff9fb 0%, #fff0f5 100%);
            padding: 40px;
            font-family: 'Quicksand', sans-serif;
            position: relative;
        }
        .pdf-journal::before { content: "🌸"; position: absolute; top: 20px; left: 20px; font-size: 60px; opacity: 0.1; }
        .pdf-journal::after { content: "💕"; position: absolute; bottom: 20px; right: 20px; font-size: 60px; opacity: 0.1; }
        .pdf-header { text-align: center; margin-bottom: 40px; padding-bottom: 20px; border-bottom: 2px dashed #ffb7c5; }
        .pdf-header h1 { font-family: 'Playfair Display', serif; font-size: 2.5rem; color: #ff8aa8; }
        .pdf-section { background: white; border-radius: 25px; padding: 25px; margin-bottom: 25px; border-left: 5px solid #ffb7c5; }
        .pdf-section h3 { color: #ff8aa8; margin-bottom: 15px; display: flex; align-items: center; gap: 10px; }
        .mood-entry-pdf, .chat-entry-pdf, .goal-pdf { padding: 12px; border-bottom: 1px solid #ffe4ed; margin-bottom: 8px; }

        footer { background: linear-gradient(135deg, #f5e6ec 0%, #ffebf0 100%); text-align: center; padding: 3rem; margin-top: 4rem; color: #aa8c9e; }
        @media (max-width: 768px) {
            .nav-links { display: none; position: absolute; top: 100%; left: 0; right: 0; background: white; flex-direction: column; padding: 1rem; text-align: center; }
            .nav-links.active { display: flex; }
            .mobile-menu { display: block; }
            .mood-grid { grid-template-columns: repeat(3, 1fr); }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo" onclick="showPage('home')"><span class="logo-icon">🌸</span><span class="logo-text">SereneMind</span></div>
            <ul class="nav-links" id="navLinks">
                <li><a onclick="showPage('home')"><i class="fas fa-home"></i> Home</a></li>
                <li><a onclick="showPage('dashboard')"><i class="fas fa-chart-line"></i> Dashboard</a></li>
                <li><a onclick="showPage('chatbot')"><i class="fas fa-robot"></i> SereneAI</a></li>
                <li><a onclick="showPage('mood')"><i class="fas fa-smile"></i> Mood Journal</a></li>
                <li><a onclick="showPage('products')"><i class="fas fa-store"></i> Wellness Shop</a></li>
                <li><a onclick="showPage('appointments')"><i class="fas fa-calendar-check"></i> Consult</a></li>
